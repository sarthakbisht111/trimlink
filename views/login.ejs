<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - TrimLink</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background:#0f172a;
            display:flex;
            justify-content:center;
            align-items:center;
            min-height:100vh;
            padding:20px;
        }

        .card{
            width:100%;
            max-width:450px;
            background:#1e293b;
            padding:40px;
            border-radius:20px;
            box-shadow:0 10px 30px rgba(0,0,0,0.25);
        }

        h1{
            color:white;
            margin-bottom:10px;
        }

        .subtitle{
            color:#94a3b8;
            margin-bottom:30px;
        }

        form{
            display:flex;
            flex-direction:column;
            gap:18px;
        }

        label{
            color:#cbd5e1;
            font-size:0.95rem;
        }

        input{
            width:100%;
            margin-top:8px;
            padding:14px;
            border:none;
            border-radius:12px;
            background:#334155;
            color:white;
            font-size:1rem;
            outline:none;
        }

        input::placeholder{
            color:#94a3b8;
        }

        button{
            margin-top:10px;
            padding:14px;
            border:none;
            border-radius:12px;
            background:#38bdf8;
            color:#0f172a;
            font-size:1rem;
            font-weight:bold;
            cursor:pointer;
            transition:0.3s ease;
        }

        button:hover{
            transform:translateY(-2px);
            opacity:0.9;
        }

        .signup-link{
            margin-top:25px;
            text-align:center;
            color:#94a3b8;
        }

        .signup-link a{
            color:#38bdf8;
            text-decoration:none;
            font-weight:bold;
        }
    </style>
</head>
<body>

    <div class="card">
        <h1>Welcome Back</h1>
        <p class="subtitle">Login to continue using TrimLink.</p>

        <form action="/user/login" method="post">

            <div>
                <label>Email</label>
                <input 
                    type="email" 
                    required 
                    name="email"
                    placeholder="Enter your email"
                >
            </div>

            <div>
                <label>Password</label>
                <input 
                    type="password" 
                    required 
                    name="password"
                    placeholder="Enter your password"
                >
            </div>

            <button type="submit">Login</button>
        </form>

        <div class="signup-link">
            Don't have an account?
            <a href="/signup">Signup</a>
        </div>
    </div>

</body>
</html>