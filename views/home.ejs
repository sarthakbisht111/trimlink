<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TrimLink Dashboard</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background:#0f172a;
            color:white;
            min-height:100vh;
            padding:40px;
        }

        .container{
            max-width:1100px;
            margin:auto;
        }

        .navbar{
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-bottom:40px;
        }

        .logo{
            font-size:2rem;
            font-weight:bold;
            color:#38bdf8;
        }

        .tagline{
            color:#94a3b8;
            margin-top:5px;
        }

        .card{
            background:#1e293b;
            border-radius:18px;
            padding:30px;
            margin-bottom:30px;
            box-shadow:0 10px 30px rgba(0,0,0,0.25);
        }

        .card h2{
            margin-bottom:20px;
            font-size:1.4rem;
        }

        form{
            display:flex;
            gap:15px;
            flex-wrap:wrap;
        }

        input{
            flex:1;
            min-width:250px;
            padding:14px;
            border:none;
            border-radius:12px;
            font-size:1rem;
            background:#334155;
            color:white;
        }

        input::placeholder{
            color:#94a3b8;
        }

        button{
            padding:14px 24px;
            border:none;
            border-radius:12px;
            background:#38bdf8;
            color:#0f172a;
            font-size:1rem;
            font-weight:bold;
            cursor:pointer;
            transition:0.3s ease;
        }

        button:hover{
            transform:translateY(-2px);
            opacity:0.9;
        }

        .generated-url{
            margin-top:20px;
            padding:15px;
            background:#0f172a;
            border-radius:12px;
            word-break:break-all;
        }

        .generated-url a{
            color:#38bdf8;
            text-decoration:none;
        }

        table{
            width:100%;
            border-collapse:collapse;
            margin-top:20px;
            overflow:hidden;
            border-radius:14px;
        }

        th{
            background:#38bdf8;
            color:#0f172a;
            padding:15px;
            text-align:left;
        }

        td{
            padding:15px;
            border-bottom:1px solid #334155;
            background:#1e293b;
            color:#e2e8f0;
        }

        tr:hover td{
            background:#273449;
        }

        .empty-state{
            text-align:center;
            padding:40px;
            color:#94a3b8;
        }

        @media(max-width:768px){
            body{
                padding:20px;
            }

            form{
                flex-direction:column;
            }

            button{
                width:100%;
            }

            table{
                display:block;
                overflow-x:auto;
            }
        }
    </style>
</head>
<body>

    <div class="container">

        <div class="navbar">
            <div>
                <div class="logo">TrimLink</div>
                <div class="tagline">Simple & Fast URL Shortener</div>
            </div>
        </div>

        <div class="card">
            <h2>Generate Short URL</h2>

            <form method="POST" action="/url" autocomplete="off">
                <input 
                    type="text"
                    name="url"
                    placeholder="https://example.com"
                    required
                />

                <button type="submit">Generate</button>
            </form>

            <% if (locals.id) { %>
                <div class="generated-url">
                    <strong>Generated URL:</strong>
                    <br><br>

                    <a 
                        target="_blank" 
                        href="/url/<%= id %>"
                        style="color:#38bdf8; text-decoration:none;"
                    >
                        https://trimlink1.onrender.com/url/<%= id %>
                    </a>
                </div>
            <% } %>
        </div>

        <div class="card">
            <h2>Your URLs</h2>

            <% if (locals.urls && urls.length > 0) { %>
                <table>
                    <thead>
                        <tr>
                            <th>S.No</th>
                            <th>Short ID</th>
                            <th>Original URL</th>
                            <th>Clicks</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% urls.forEach((url,index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td><%= url.shortId %></td>
                                <td><%= url.redirectURL %></td>
                                <td><%= url.visitHistory.length %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <div class="empty-state">
                    No URLs created yet.
                </div>
            <% } %>
        </div>

    </div>

</body>
</html>